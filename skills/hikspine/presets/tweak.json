{
  "name": "tweak",
  "description": "Preset path: small change (copy/config/docs). Skips brainstorming and full plan. open -> build -> verify -> archive.",
  "defaults": {
    "build_mode": "direct",
    "build_pause": null,
    "subagent_dispatch": null,
    "tdd_mode": "direct",
    "review_mode": "off",
    "isolation": "branch",
    "verify_mode": "light",
    "design_doc": null,
    "plan": null
  },
  "phases": [
    {
      "id": "open",
      "skill": "hikspine-open",
      "steps": [
        { "role": "formalize", "skill": "openspec-propose", "note": "OpenSpec 精简形式化（tweak：proposal + tasks）" }
      ],
      "guard": { "artifacts": ["proposal.md", "tasks.md"] },
      "onComplete": "build"
    },
    {
      "id": "build",
      "skill": "hikspine-tweak",
      "guard": {
        "state": {
          "isolation": ["branch", "worktree"],
          "build_mode": ["subagent-driven-development", "executing-plans", "direct"]
        }
      },
      "onComplete": "verify",
      "onCompleteSet": {
        "verify_result": "pending",
        "verification_report": "null",
        "branch_status": "pending"
      }
    },
    {
      "id": "verify",
      "skill": "hikspine-verify",
      "steps": [
        { "role": "verify", "skill": "verification-before-completion", "note": "Superpowers 验证方法论（tweak 走轻量验证）" },
        { "role": "spec-verify", "skill": "openspec-verify-change", "note": "OpenSpec 规格覆盖验证（仅 verify_mode=full 时）" },
        { "role": "finish", "skill": "finishing-a-development-branch", "note": "Superpowers 分支收尾" }
      ],
      "guard": {
        "state": {
          "verification_report": "exists",
          "branch_status": "handled"
        }
      },
      "onComplete": "archive",
      "onCompleteSet": { "verify_result": "pass", "verified_at": "@date" },
      "onFail": "build",
      "onFailSet": { "verify_result": "fail" }
    },
    {
      "id": "archive",
      "skill": "hikspine-archive",
      "steps": [
        { "role": "archive", "skill": "openspec-archive-change", "note": "OpenSpec 合并 delta spec 进主 spec 并归档" }
      ],
      "terminal": true,
      "onCompleteSet": { "archived": "true" }
    }
  ]
}
