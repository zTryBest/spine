# Keep shell scripts and skill text LF across platforms. Vendored upstream
# scripts (superpowers/openspec) must stay LF to run on macOS/Linux.
*.sh   text eol=lf
*.bash text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.ts   text eol=lf
